# URL-encode the password before pasting it here.
# Example: p@ss#word becomes p%40ss%23word
DATABASE_URL="postgresql://postgres.rirljpqsxbkghokckffl:[URL-ENCODED-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
DIRECT_URL="postgresql://postgres.rirljpqsxbkghokckffl:[URL-ENCODED-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require"
APP_SECRET="replace-with-a-long-random-secret"
AUTH_HASH_PEPPER="replace-with-a-second-long-random-secret"
FRONTEND_ORIGIN="http://localhost:3000"
PORT="4000"

# OTP delivery
# local default: console
# production default: brevo_email
# use console_and_brevo_email locally when you want console logging and real email delivery together.
OTP_SENDER_MODE="console_and_brevo_email"

# Brevo transactional email
BREVO_API_KEY="replace-with-brevo-api-key"
BREVO_SEND_EMAIL_URL="https://api.brevo.com/v3/smtp/email"
BREVO_EMAIL_SENDER_NAME="SME Paddy"
BREVO_EMAIL_SENDER_EMAIL="replace-with-verified-brevo-sender-email"
BREVO_OTP_EMAIL_SUBJECT="Your SME Paddy code"

# Brevo SMS
BREVO_SEND_SMS_URL="https://api.brevo.com/v3/transactionalSMS/send"
# SMS sender is not the email sender shown under Senders/domains/IPs.
# Use 3-11 letters/numbers only, and register it in Brevo if your target country requires it.
BREVO_SMS_SENDER="SMEPaddy"
BREVO_SMS_TYPE="transactional"
BREVO_ORGANISATION_PREFIX="SME Paddy"

# Termii SMS, kept as an optional fallback/provider.
TERMII_BASE_URL="https://api.ng.termii.com/api"
TERMII_SEND_SMS_PATH="/sms/send"
# Optional override if your Termii dashboard gives you a full message endpoint.
# TERMII_SEND_SMS_URL="https://v3.api.termii.com/api/sms/send"
TERMII_API_KEY="replace-with-termii-api-key"
# Must be an approved/available sender ID in your Termii dashboard.
# For production, register/approve your brand sender ID.
TERMII_SENDER_ID="replace-with-approved-termii-sender-id"
TERMII_CHANNEL="generic"
