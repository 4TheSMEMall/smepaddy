generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  AUTH_PENDING
  PHONE_PENDING
  OTP_VERIFIED
  ONBOARDED
}

enum OtpPurpose {
  LOGIN
  SIGNUP
}

enum StockItemType {
  PRODUCT
  SERVICE
}

enum StockOwnershipType {
  OWNED
  CONSIGNMENT
}

enum StockMovementType {
  OPENING_STOCK
  MANUAL_ADJUSTMENT
  SALE
  RESTOCK
  RETURN
  DAMAGE
}

enum PaymentStatus {
  PAID
  PART_PAYMENT
  WILL_PAY_LATER
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
}

enum InvoiceStatus {
  PAID
  PENDING
  OVERDUE
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum LoanType {
  NANO
  MICRO
  SMALL
  GROWTH
}

enum LoanStatus {
  ACTIVE
  COMPLETED
  DEFAULTED
}

model User {
  id              String           @id @default(cuid())
  phone           String?          @unique
  firebaseUid     String?          @unique
  fullName        String?
  email           String?          @unique
  pinHash         String?
  status          UserStatus       @default(AUTH_PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  otpCodes        OtpCode[]
  authSessions    AuthSession[]
  businessProfile BusinessProfile?
}

model OtpCode {
  id           String     @id @default(cuid())
  phone        String
  codeHash     String
  purpose      OtpPurpose @default(SIGNUP)
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int        @default(0)
  createdAt    DateTime   @default(now())
  userId        String?
  user          User?      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, purpose, consumedAt, expiresAt])
  @@index([phone, createdAt])
}

model OtpRequestThrottle {
  phone                 String   @id
  lastRequestedAt       DateTime
  hourlyWindowStartedAt DateTime
  hourlyCount           Int      @default(1)
  updatedAt             DateTime @updatedAt

  @@index([updatedAt])
}

model BusinessProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  businessName String
  businessType String
  location     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  suppliers    Supplier[]
  stockItems   StockItem[]
  invoices     Invoice[]
  sales        SaleTransaction[]
  expenses             ExpenseTransaction[]
  recurringExpenses    RecurringExpense[]
  wallet               Wallet?
  streak               UserStreak?
  coinRedemptions      CoinRedemption[]
  deviceTokens         DeviceToken[]
  loans                Loan[]
  savingsEntries       SavingsEntry[]
  savingsTarget        SavingsTarget?
  savingsAccount       SavingsAccount?
  consignmentSettlements ConsignmentSettlement[]
}

model AuthSession {
  id         String    @id
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Supplier {
  id                String          @id @default(cuid())
  businessProfileId String
  name              String
  phone             String?
  email             String?
  bankName          String?
  accountName       String?
  accountNumber     String?
  address           String?
  notes             String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  stockItems        StockItem[]
  consignmentSettlements ConsignmentSettlement[]

  @@unique([businessProfileId, name])
  @@index([businessProfileId])
}

model StockItem {
  id                     String             @id @default(cuid())
  businessProfileId      String
  supplierId             String?
  sku                    String
  name                   String
  description            String?
  category               String
  itemType               StockItemType      @default(PRODUCT)
  ownershipType          StockOwnershipType @default(OWNED)
  unitType               String             @default("Pieces")
  buyingPriceKobo        Int                @default(0)
  sellingPriceKobo       Int                @default(0)
  wholesalePriceKobo     Int                @default(0)
  ownerCostPerUnitKobo   Int?
  quantity               Int                @default(0)
  lowStockAlertQuantity  Int?
  preferredReorderAmount Int?
  version                Int                @default(1)
  archivedAt             DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  businessProfile        BusinessProfile    @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  supplier               Supplier?          @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  movements              StockMovement[]
  saleLineItems          SaleLineItem[]
  invoiceItems           InvoiceItem[]
  consignmentSettlements ConsignmentSettlement[]

  @@unique([businessProfileId, sku])
  @@index([businessProfileId, archivedAt])
  @@index([businessProfileId, category])
  @@index([businessProfileId, ownershipType])
  @@index([businessProfileId, itemType])
  @@index([businessProfileId, quantity])
}

model ConsignmentSettlement {
  id                String          @id @default(cuid())
  businessProfileId String
  supplierId        String
  stockItemId       String?
  amountKobo        Int
  paymentMethod     PaymentMethod
  reference         String?
  notes             String?
  createdAt         DateTime        @default(now())
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  supplier          Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  stockItem         StockItem?      @relation(fields: [stockItemId], references: [id], onDelete: SetNull)

  @@index([businessProfileId, createdAt])
  @@index([supplierId, createdAt])
  @@index([stockItemId, createdAt])
}

model Invoice {
  id                String            @id @default(cuid())
  businessProfileId String
  customerName      String
  customerPhone     String?
  status            InvoiceStatus     @default(PENDING)
  subtotalKobo      Int
  amountPaidKobo    Int               @default(0)
  balanceKobo       Int
  dueDate           DateTime
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  businessProfile   BusinessProfile   @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  items             InvoiceItem[]
  sales             SaleTransaction[]
  payments          InvoicePayment[]

  @@index([businessProfileId, status])
  @@index([businessProfileId, dueDate])
}

model InvoicePayment {
  id                String        @id @default(cuid())
  invoiceId         String
  businessProfileId String
  amountKobo        Int
  paymentMethod     PaymentMethod
  note              String?
  createdAt         DateTime      @default(now())
  invoice           Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId, createdAt])
  @@index([businessProfileId, createdAt])
}

model InvoiceItem {
  id            String    @id @default(cuid())
  invoiceId     String
  stockItemId   String?
  description   String
  quantity      Int
  unitPriceKobo Int
  totalKobo     Int
  invoice       Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  stockItem     StockItem? @relation(fields: [stockItemId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([stockItemId])
}

model SaleTransaction {
  id                String          @id @default(cuid())
  businessProfileId String
  invoiceId         String?
  customerName      String?
  paymentStatus     PaymentStatus
  paymentMethod     PaymentMethod?
  subtotalKobo      Int
  amountPaidKobo    Int
  balanceKobo       Int
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  invoice           Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  lineItems         SaleLineItem[]

  @@index([businessProfileId, createdAt])
  @@index([businessProfileId, paymentStatus])
  @@index([invoiceId])
}

model SaleLineItem {
  id                String          @id @default(cuid())
  saleTransactionId String
  stockItemId        String
  quantity           Int
  unitPriceKobo      Int
  totalKobo          Int
  saleTransaction    SaleTransaction @relation(fields: [saleTransactionId], references: [id], onDelete: Cascade)
  stockItem          StockItem       @relation(fields: [stockItemId], references: [id], onDelete: Restrict)

  @@index([saleTransactionId])
  @@index([stockItemId])
}

model ExpenseTransaction {
  id                String          @id @default(cuid())
  businessProfileId String
  category          String
  amountKobo        Int
  description       String?
  paymentMethod     PaymentMethod
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([businessProfileId, createdAt])
  @@index([businessProfileId, category])
}

model Loan {
  id                String          @id @default(cuid())
  businessProfileId String
  loanType          LoanType
  status            LoanStatus      @default(ACTIVE)
  principalKobo     Int
  interestKobo      Int
  totalKobo         Int
  amountRepaidKobo  Int             @default(0)
  balanceKobo       Int
  tenureDays        Int
  dueDate           DateTime
  pcsAtApplication  Int
  disbursedAt       DateTime        @default(now())
  completedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  repayments        LoanRepayment[]

  @@index([businessProfileId, status])
  @@index([businessProfileId, createdAt])
}

model LoanRepayment {
  id            String        @id @default(cuid())
  loanId        String
  amountKobo    Int
  paymentMethod PaymentMethod
  paidOnTime    Boolean
  note          String?
  createdAt     DateTime      @default(now())
  loan          Loan          @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId, createdAt])
}

model DeviceToken {
  id                String          @id @default(cuid())
  businessProfileId String
  token             String          @unique
  subscription      String?         // Full PushSubscription JSON for web-push
  platform          String          @default("web")
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([businessProfileId, isActive])
}

enum SavingsEntryStatus {
  DECLARED
  RECONCILED
  VERIFIED
}

enum SavingsTargetPeriod {
  DAILY
  WEEKLY
  MONTHLY
}

model SavingsEntry {
  id                    String             @id @default(cuid())
  businessProfileId     String
  amount                Decimal            @db.Decimal(12, 2)
  note                  String?
  savedAt               DateTime
  status                SavingsEntryStatus @default(DECLARED)
  // Verification (Flutterwave payment)
  verificationReference String?
  verificationTransferId String?
  verifiedAt            DateTime?
  // Payout (Flutterwave transfer)
  payoutStatus          String?
  payoutReference       String?
  payoutTransferId      String?
  payoutFailureReason   String?
  payoutTransferredAt   DateTime?
  reconciledAt          DateTime?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  businessProfile       BusinessProfile    @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  verificationAttempts  SavingsVerificationAttempt[]

  @@index([businessProfileId, savedAt])
  @@index([businessProfileId, status])
}

model SavingsVerificationAttempt {
  id                   String   @id @default(cuid())
  businessProfileId    String
  savingsEntryId       String
  reference            String   @unique
  expectedAmount       Decimal  @db.Decimal(12, 2)
  status               String   @default("PENDING")
  authorizationUrl     String
  accessCode           String?
  paystackEmail        String
  flwTransactionId     String?
  flwReference         String?
  expiresAt            DateTime?
  verifiedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  savingsEntry         SavingsEntry @relation(fields: [savingsEntryId], references: [id], onDelete: Cascade)

  @@index([savingsEntryId])
  @@index([businessProfileId, reference])
}

model SavingsTarget {
  id                String              @id @default(cuid())
  businessProfileId String              @unique
  amount            Decimal             @db.Decimal(12, 2)
  period            SavingsTargetPeriod @default(DAILY)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  businessProfile   BusinessProfile     @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
}

model SavingsAccount {
  id                String          @id @default(cuid())
  businessProfileId String          @unique
  bankName          String
  bankCode          String
  accountNumber     String
  accountName       String
  setupAt           DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
}

model CoinRedemption {
  id                String          @id @default(cuid())
  businessProfileId String
  coinsSpent        Int
  tier              String
  rewardType        String
  rewardValue       Int
  status            String          @default("PENDING")
  note              String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([businessProfileId, createdAt])
}

model Wallet {
  id                String            @id @default(cuid())
  businessProfileId String            @unique
  totalEarned       Int               @default(0)
  availableBalance  Int               @default(0)
  redeemedTotal     Int               @default(0)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  businessProfile   BusinessProfile   @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
  transactions      CoinTransaction[]
}

model CoinTransaction {
  id          String   @id @default(cuid())
  walletId    String
  amount      Int
  eventKey    String
  referenceId String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  wallet      Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt])
  @@index([walletId, eventKey, createdAt])
}

model UserStreak {
  id                String          @id @default(cuid())
  businessProfileId String          @unique
  currentStreak     Int             @default(0)
  longestStreak     Int             @default(0)
  lastActiveDate    DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)
}

model RecurringExpense {
  id                String             @id @default(cuid())
  businessProfileId String
  category          String
  amountKobo        Int
  description       String?
  paymentMethod     PaymentMethod
  frequency         RecurringFrequency
  dayOfWeek         Int?
  dayOfMonth        Int?
  hourOfDay         Int                @default(8)
  isActive          Boolean            @default(true)
  startDate         DateTime
  endDate           DateTime?
  lastRunAt         DateTime?
  nextRunAt         DateTime
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  businessProfile   BusinessProfile    @relation(fields: [businessProfileId], references: [id], onDelete: Cascade)

  @@index([nextRunAt, isActive])
  @@index([businessProfileId])
}

model StockMovement {
  id                String            @id @default(cuid())
  stockItemId       String
  businessProfileId String
  type              StockMovementType
  quantityChange    Int
  quantityBefore    Int
  quantityAfter     Int
  note              String?
  createdAt         DateTime          @default(now())
  stockItem         StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([businessProfileId, createdAt])
  @@index([stockItemId, createdAt])
  @@index([type])
}
